{
  "name": "webb3-backend-api",
  "type": "module",
  "version": "0.0.0",
  "license": "GPL-3.0",
  "private": true,
  "engines": {
    "node": ">=19.4.0"
  },
  "dependencies": {
    "@compound-finance/sleuth": "^1.0.1-alpha4",
    "@ethersproject/abi": "5.6",
    "js-sha3": "0.8.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20240314.0",
    "@ethersproject/hash": "5.6",
    "@types/node": "^18.0.6",
    "tap": "^21",
    "typescript": "^5",
    "wrangler": "^4.59.1"
  },
  "overrides": {
    "elliptic": "^6.6.1",
    "shell-quote": "^1.8.4",
    "undici": "^6.24.0",
    "node-forge": "^1.4.0",
    "ws": "^8.21.0",
    "lodash": "^4.17.23",
    "minimatch": "^9.0.7",
    "picomatch": "^2.3.2",
    "tmp": "^0.2.6",
    "braces": "^3.0.3",
    "cross-spawn": "^7.0.5",
    "path-to-regexp": "^8.2.0",
    "bn.js": "^5.2.3",
    "brace-expansion": "^2.0.2",
    "js-yaml": "^4.1.1",
    "@babel/helpers": "^7.26.10",
    "@babel/core": "^7.29.6",
    "esbuild": "^0.25.0",
    "follow-redirects": "^1.15.6",
    "nanoid": "^3.3.8",
    "uuid": "^11.1.1",
    "yaml": "^2.4.2",
    "cookie": "^0.7.0",
    "diff": "^5.2.2"
  },
  "tap": {
    "node-arg": [
      "--no-warnings"
    ]
  },
  "config": {
    "local": "localhost:8787"
  },
  "scripts": {
    "preinstall": "cd .. && npm install-clean --workspaces && npm run build --workspaces && npm test --workspaces",
    "pretest": "tsc",
    "test": "npm run test:tap",
    "test:tap": "npx tap --disable-coverage --timeout=900 'dist/tests/**/*.test.js'",
    "build": "npx tsc",
    "start": "wrangler dev --local entrypoint.ts",
    "deploy:stage": "npx wrangler deploy --env stage",
    "deploy:production": "npx wrangler deploy --env production"
  }
}
